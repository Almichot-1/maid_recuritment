PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/maid_recruitment?sslmode=disable
JWT_SECRET=replace-with-a-long-random-secret

# Optional today. Keep empty unless you add Redis-backed features.
REDIS_URL=

# S3-compatible object storage. Works with AWS S3, Cloudflare R2, MinIO, etc.
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET=maid-recruitment
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Maid Recruitment

# Public app URL used in emails and links.
APP_BASE_URL=http://localhost:3000

# Browser origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Leave true for local all-in-one development. Set false on the web API in production
# when the dedicated expiry worker / cron job is enabled.
RUN_EXPIRY_SCHEDULER=true
